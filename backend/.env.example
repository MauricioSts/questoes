# Porta do servidor
PORT=3333

# Postgres — ajuste usuário/senha/host/db
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/questoes?schema=public"

# CORS — domínio do frontend (produção: https://mauriciosts.com)
CORS_ORIGIN="http://localhost:5173"

# JWT — gere segredos fortes (ex.: openssl rand -hex 32). NÃO comitar os reais.
JWT_ACCESS_SECRET="troque-por-um-segredo-forte-access"
JWT_REFRESH_SECRET="troque-por-um-segredo-forte-refresh"
ACCESS_TOKEN_TTL="15m"
REFRESH_TOKEN_TTL_DAYS=30

# Usuário inicial criado pelo seed
SEED_EMAIL="contatomauriciosts@gmail.com"
SEED_PASSWORD="troque-esta-senha"
SEED_NOME="Mauricio"

# Fuso do usuário (usado no cálculo de meta diária / streak)
USER_TIMEZONE="America/Fortaleza"

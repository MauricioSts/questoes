// Prisma schema — banco de questões.
// Regra central: o backend NUNCA guarda enunciado/alternativas/gabarito. Só o resultado
// da resposta com snapshots de modulo/materia/assunto/dificuldade, o que permite gerar
// estatística e priorizar erradas sem depender do JSON de questões.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Contexto {
  ESTUDO
  FLASH
  SIMULADO
  TOPICO
}

// Banco de questões (conteúdo). Compartilhado entre usuários (não é escopo por userId).
// A correção de acerto continua no frontend; o backend só guarda e serve o conteúdo.
model Questao {
  id           Int      @id // ID definido no lote (usado como questaoId em Answer)
  modulo       String // "I" | "II"
  materia      String
  assunto      String
  dificuldade  String // facil | media | dificil
  textoBaseKey String? // chave em TextoBase (questões de inglês)
  enunciado    String
  codigo       String? // bloco de código opcional
  linguagem    String? // rótulo da linguagem do código
  alternativas Json // { "A": "...", "B": "...", ... }
  gabarito     String
  explicacao   String
  loteNome     String? // rótulo do lote (nome do arquivo importado); null p/ imports antigos
  createdAt    DateTime @default(now()) // idêntico p/ toda questão de um mesmo import → chave do lote

  @@index([modulo, materia])
  @@index([createdAt])
}

model TextoBase {
  chave String @id
  texto String
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  nome         String
  metaDiaria   Int       @default(70) // meta diária de questões (configurável no futuro)
  dataProva    DateTime? // data alvo da prova (configurável pelo usuário)
  createdAt    DateTime  @default(now())

  answers       Answer[]
  notas         Nota[]
  marcadas      Marcada[]
  refreshTokens RefreshToken[]
  sessaoAtiva   SessaoAtiva?
}

// Sessão de estudo em andamento (uma por usuário). Guarda apenas a ORDEM dos IDs e
// o cursor — o conteúdo continua no frontend e as respostas são persistidas em Answer.
// Permite ao usuário sair no meio e retomar de onde parou ("Continuar estudando").
model SessaoAtiva {
  id         String   @id @default(cuid())
  userId     String   @unique
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  contexto   Contexto @default(ESTUDO)
  questaoIds Int[] // ordem das questões da sessão
  cursor     Int      @default(0) // índice da questão atual
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// Cada tentativa de resposta. Snapshots permitem estatística/sorteio sem o JSON.
model Answer {
  id                  String   @id @default(cuid())
  clientId            String?  @unique // id gerado no cliente p/ deduplicar reenvios (fila offline)
  userId              String
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  questaoId           Int
  moduloSnapshot      String // "I" (gerais) | "II" (específicos)
  materiaSnapshot     String
  assuntoSnapshot     String
  dificuldadeSnapshot String // facil | media | dificil
  alternativaMarcada  String
  acertou             Boolean
  tempoSegundos       Int?
  contexto            Contexto
  createdAt           DateTime @default(now())

  @@index([userId, createdAt])
  @@index([userId, acertou, moduloSnapshot])
  @@index([userId, questaoId])
}

// Anotação do usuário na questão — uma por questão por usuário.
model Nota {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  questaoId Int
  texto     String
  updatedAt DateTime @updatedAt

  @@unique([userId, questaoId])
}

// "Marcar questão pra revisar depois" — flag por questão por usuário.
model Marcada {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  questaoId Int
  createdAt DateTime @default(now())

  @@unique([userId, questaoId])
}

// Refresh tokens persistidos (hash) para permitir logout/revogação.
model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}
